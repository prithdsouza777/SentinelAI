{
  "name": "sentinelai",
  "version": "0.1.0",
  "private": true,
  "description": "SentinelAI — Autonomous AI Contact Center Intelligence Platform for AWS Connect",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "cd frontend && npm run build",
    "lint": "concurrently \"npm run lint:frontend\" \"npm run lint:backend\"",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && ruff check .",
    "test": "concurrently \"npm run test:frontend\" \"npm run test:backend\"",
    "test:frontend": "cd frontend && npm run test",
    "test:backend": "cd backend && pytest",
    "infra:synth": "cd infra && cdk synth",
    "infra:deploy": "cd infra && cdk deploy"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
