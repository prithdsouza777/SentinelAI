# SentinelAI Backend Configuration

# Mode
SIMULATION_MODE=true

# Google Gemini API (preferred for demo — fast + cheap)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
TEMPERATURE=0.01

# AWS Credentials (for Bedrock fallback)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Anthropic API (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Amazon Bedrock (fallback if no Gemini/Anthropic key)
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# Redis (optional — graceful fallback to in-memory)
REDIS_URL=redis://localhost:6379

# DynamoDB (optional)
DYNAMODB_ENDPOINT=http://localhost:8042
DYNAMODB_REGION=us-east-1

# AWS Connect (Week 4 — not needed for demo)
CONNECT_INSTANCE_ID=
CONNECT_REGION=us-east-1

# Notifications — Microsoft Teams
TEAMS_WEBHOOK_URL=
TEAMS_NOTIFY_ON=critical          # critical | warning | all | none

# Notifications — Gmail SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                            # your Gmail address
SMTP_PASSWORD=                        # Gmail App Password (not your login password)
SMTP_FROM=                            # same as SMTP_USER, or leave blank
SMTP_TO=                              # comma-separated recipient emails
EMAIL_NOTIFY_ON=critical              # critical | warning | all | none
NOTIFICATION_COOLDOWN=60          # min seconds between notifications per channel

# CORS
CORS_ORIGINS=http://localhost:5173
