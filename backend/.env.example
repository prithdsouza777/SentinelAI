# SentinelAI Backend Configuration

# Mode
SIMULATION_MODE=true

# AWS Bedrock (primary LLM provider)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Anthropic API (fallback LLM provider)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
TEMPERATURE=0.01

# Notifications — Microsoft Teams (Incoming Webhook)
TEAMS_WEBHOOK_URL=
TEAMS_NOTIFY_ON=none                  # critical | warning | all | none (disabled — use Teams Bot for approvals instead)

# Microsoft Teams Bot (Bot Framework)
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_SECRET=
TEAMS_BOT_TENANT_ID=                        # required for single-tenant bots

# Notifications — Gmail SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                            # your Gmail address
SMTP_PASSWORD=                        # Gmail App Password (not your login password)
SMTP_FROM=                            # same as SMTP_USER, or leave blank
SMTP_TO=                              # comma-separated recipient emails
EMAIL_NOTIFY_ON=critical              # critical | warning | all | none
NOTIFICATION_COOLDOWN=60              # min seconds between notifications per channel

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# OAuth — Microsoft (https://portal.azure.com → App registrations)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/auth/microsoft/callback
MICROSOFT_TENANT_ID=common              # "common" for multi-tenant, or your Azure tenant ID

# JWT
JWT_SECRET=sentinelai-dev-secret-change-in-production
JWT_EXPIRY_HOURS=8

# Frontend URL (for OAuth callback redirects)
FRONTEND_URL=http://localhost:5173

# CORS
CORS_ORIGINS=http://localhost:5173
